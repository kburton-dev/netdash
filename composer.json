{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.10.5",
        "laravel/framework": "^11.54.0",
        "laravel/octane": "^2.17.4",
        "laravel/sanctum": "^4.3.2",
        "laravel/tinker": "^2.11.1",
        "livewire/livewire": "^3.8.0",
        "livewire/volt": "^1.10.5",
        "saloonphp/xml-wrangler": "^1.5.0",
        "spatie/flysystem-dropbox": "^3.1.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16.5",
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^2.11.2",
        "laravel/breeze": "^2.4.2",
        "laravel/pint": "^1.29.1",
        "maantje/xhprof-buggregator-laravel": "^0.5.1",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.5.0",
        "pestphp/pest": "^2.36.1",
        "pestphp/pest-plugin-laravel": "^2.4",
        "spatie/laravel-ignition": "^2.12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "sa": [
            "@php vendor/bin/phpstan analyse"
        ],
        "gb": [
            "@php vendor/bin/phpstan analyse --generate-baseline"
        ],
        "dm": [
            "@php artisan ide-helper:models -W",
            "vendor/bin/pint app/Models"
        ],
        "qa": [
            "vendor/bin/pint --test",
            "vendor/bin/phpstan analyse",
            "vendor/bin/pest"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
